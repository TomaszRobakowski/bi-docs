# Copy to .env, fill in values, then run: ./scripts/build.sh
# The .env file is used only at build time. Upload dist/ to your web server.
at_property=your-adobe-target-property-token
metarouter_write_key=your-metarouter-write-key
metarouter_host=https://mr.example.com
metarouter_client_name=your-client-name
metarouter_container_id=container-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
metarouter_gcs_base=https://storage.googleapis.com/metatagger-479114-builds
onetrust_domain_id=your-onetrust-domain-script-id
onetrust_target_category_id=C0004
target_script_url=./at.js
